{
  "rewrites": [
    { "source": "/card", "destination": "/card.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.vcf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/vcard; charset=utf-8"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ]
}
