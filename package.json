{
  "name": "clearstack-digital-card",
  "private": true,
  "scripts": {
    "build:vcf": "node scripts/build-vcf.mjs",
    "prestart": "npm run build:vcf",
    "start": "serve . -l 3000",
    "preview": "serve . -l 3000",
    "vendor:qrcode": "esbuild node_modules/qrcode/lib/browser.js --bundle --platform=browser --format=iife --global-name=QRCode --minify --outfile=vendor/qrcode.min.js",
    "vercel-build": "npm run vendor:qrcode && npm run build:vcf"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "qrcode": "^1.5.4",
    "serve": "^14.2.4"
  }
}
